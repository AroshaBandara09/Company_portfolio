---
// src/components/common/Header.astro
---

<header class="header">
  <nav class="navbar container">
    <!-- Logo Area -->
    <div class="logo">
      <a href="/">
        <div class="logo-wrapper">
          <span class="logo-main">Zynthera</span>
          <span class="logo-tagline">Connecting the Future</span>
        </div>
      </a>
    </div>

    <!-- Desktop Navigation -->
    <ul class="nav-links">
      <li><a href="#solutions">Solutions</a></li>
      <li><a href="#technology">Technology</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#insights">Insights</a></li>
    </ul>

    <!-- CTA Button -->
    <div class="nav-cta">
      <a href="#contact" class="btn-primary">Get Connected</a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Menu">
      <span class="hamburger"></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <ul class="mobile-nav-links">
      <li><a href="#solutions">Solutions</a></li>
      <li><a href="#technology">Technology</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#insights">Insights</a></li>
    </ul>
    <div class="mobile-cta">
      <a href="#contact" class="btn-primary">Get Connected</a>
    </div>
  </div>
</header>

<style is:global>
  /* Header Base */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000; /* Higher than footer */
    background: transparent;
    transition: all 0.3s ease;
  }

  .header.scrolled {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    box-shadow: 0 2px 20px rgba(0, 102, 204, 0.08);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    transition: padding 0.3s ease;
  }

  .header.scrolled .navbar {
    padding: 12px 0;
  }

  /* Logo Styles - Blue Theme */
  .logo a {
    text-decoration: none;
  }

  .logo-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .logo-main {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #0066cc 0%, #004999 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1.2;
  }

  .logo-tagline {
    font-size: 0.7rem;
    font-weight: 500;
    color: #0066cc;
    letter-spacing: 0.5px;
    opacity: 0.8;
  }

  /* Navigation Links */
  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    text-decoration: none;
    color: #2c3e50;
    font-weight: 500;
    font-size: 1rem;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-links a:hover {
    color: #0066cc;
  }

  /* Blue Underline Animation */
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: #0066cc;
    transition: width 0.3s ease;
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* CTA Button - Blue Theme */
  .btn-primary {
    display: inline-block;
    padding: 10px 28px;
    background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
    color: white;
    text-decoration: none;
    border-radius: 40px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    border: none;
    box-shadow: 0 2px 8px rgba(0, 102, 204, 0.2);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 102, 204, 0.3);
    background: linear-gradient(135deg, #0052a3 0%, #003d7a 100%);
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 1001;
  }

  .hamburger {
    display: block;
    width: 24px;
    height: 2px;
    background: #0066cc;
    position: relative;
    transition: all 0.3s ease;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background: #0066cc;
    transition: all 0.3s ease;
  }

  .hamburger::before {
    top: -8px;
  }

  .hamburger::after {
    bottom: -8px;
  }

  /* Mobile Menu Active State */
  .mobile-menu-btn.active .hamburger {
    background: transparent;
  }

  .mobile-menu-btn.active .hamburger::before {
    transform: rotate(45deg);
    top: 0;
    background: #0066cc;
  }

  .mobile-menu-btn.active .hamburger::after {
    transform: rotate(-45deg);
    bottom: 0;
    background: #0066cc;
  }

  /* Mobile Menu Panel */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: -100%;
    width: 80%;
    max-width: 400px;
    height: 100vh;
    background: white;
    box-shadow: -2px 0 30px rgba(0, 0, 0, 0.1);
    padding: 100px 32px 32px;
    transition: right 0.3s ease;
    z-index: 999;
  }

  .mobile-menu.active {
    right: 0;
  }

  .mobile-nav-links {
    list-style: none;
    padding: 0;
    margin: 0 0 40px 0;
  }

  .mobile-nav-links li {
    margin-bottom: 28px;
  }

  .mobile-nav-links a {
    text-decoration: none;
    color: #2c3e50;
    font-size: 1.25rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .mobile-nav-links a:hover {
    color: #0066cc;
    padding-left: 8px;
    transition: padding 0.2s ease;
  }

  .mobile-cta .btn-primary {
    width: 100%;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container {
      padding: 0 20px;
    }

    .nav-links,
    .nav-cta {
      display: none;
    }

    .mobile-menu-btn {
      display: block;
    }

    .logo-main {
      font-size: 1.3rem;
    }

    .logo-tagline {
      font-size: 0.6rem;
    }
  }

  /* Desktop hover states */
  @media (min-width: 769px) {
    .nav-links {
      display: flex;
    }
  }

  /* Body scroll lock */
  body.menu-open {
    overflow: hidden;
  }

  /* Additional blue accent touches */
  .header.scrolled .logo-main {
    background: linear-gradient(135deg, #0066cc 0%, #004999 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }
</style>

<script>
  // Scroll effect for header
  window.addEventListener('scroll', () => {
    const header = document.querySelector('.header');
    if (header){
        if (window.scrollY > 50) {
            header.classList.add('scrolled');
        } else {
            header.classList.remove('scrolled');
        }
    }
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
      menuBtn.classList.toggle('active');
      document.body.classList.toggle('menu-open');
    });

    // Close mobile menu when clicking links
    const mobileLinks = document.querySelectorAll('.mobile-nav-links a, .mobile-cta a');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('active');
        menuBtn.classList.remove('active');
        document.body.classList.remove('menu-open');
      });
    });
  }
</script>